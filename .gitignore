# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Capacitor / Android build outputs (committed source stays; build artifacts don't)
/android/.gradle/
/android/.idea/
/android/local.properties
/android/build/
/android/app/build/
/android/app/release/
/android/captures/
/android/.cxx/
/android/app/release/output-metadata.json
# google-services.json is committed — needed by the CI APK build. The
# values inside are public client identifiers (project ID, API key
# scoped to this app's package name), not server secrets.
